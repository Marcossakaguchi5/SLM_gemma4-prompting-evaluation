# Configuracao usada para reproduzir a escala da rodada final do artigo.
# Copie este arquivo para .env antes de executar os pipelines completos.

SLM_MODEL_NAME=gemma4:e4b

# Rodada final: 100 instancias por dataset.
EXPERIMENT_NUM_SAMPLES=100
EXPERIMENT_SEED=20260612

PIPELINE_EXPERIMENTS=gsm8k_arc,hendrycks_math,truthfulqa
PIPELINE_CONTINUACAO_EXPERIMENTS=gsm8k_arc,hendrycks_math
PIPELINE_OUTPUT_ROOT=resultados
PIPELINE_EXECUTION_DIR=

EXPERIMENT_TASK_CONCURRENCY=16
EXPERIMENT_CALL_CONCURRENCY=4

OLLAMA_NUM_PARALLEL=4
OLLAMA_CONTEXT_LENGTH=8192
OLLAMA_MAX_LOADED_MODELS=1
OLLAMA_MAX_QUEUE=64
OLLAMA_KEEP_ALIVE=30m
OLLAMA_FLASH_ATTENTION=1

NEMOTRON_MODEL_ID=nvidia/Nemotron-Labs-Diffusion-3B
NEMOTRON_MODE=diffusion
NEMOTRON_MAX_NEW_TOKENS=128
NEMOTRON_BLOCK_LENGTH=32
NEMOTRON_THRESHOLD=0.9
NEMOTRON_TEMPERATURE=0.0
NEMOTRON_DEVICE=auto
NEMOTRON_DTYPE=auto

JUDGE_PROVIDER=openrouter
JUDGE_MODEL_NAME=deepseek/deepseek-v4-flash
OPENROUTER_API_KEY=
OPENROUTER_API_URL=https://openrouter.ai/api/v1/chat/completions
OPENROUTER_APP_URL=
OPENROUTER_APP_TITLE=SLM Prompting Evaluation

JUDGE_SEED=
JUDGE_POSITIONAL_AUDIT=true
JUDGE_ONLY_DETERMINISTIC_FALLBACK=true
JUDGE_ALLOW_SAME_MODEL=false
JUDGE_SLEEP_SECONDS=0
JUDGE_LIMIT=

SECONDARY_JUDGE_PROVIDER=openrouter
SECONDARY_JUDGE_MODEL=
SECONDARY_JUDGE_SAMPLE_RATE=0.10

ANALYSIS_SEED=
BOOTSTRAP_ITERATIONS=5000

HUMAN_EVALUATION_CSV=
HUMAN_EVALUATION_KEY=
